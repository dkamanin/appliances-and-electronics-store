<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
        "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <!-- Define checkstyle suppressions for specific files here -->
    <suppress checks="MagicNumber" files="src[/\\](test|integrationTest)[/\\]java[/\\].*\.java"/>
    <suppress checks="MethodLength" files="src[/\\](test|integrationTest)[/\\]java[/\\].*\.java"/>
    <suppress checks="MethodName" files="src[/\\](test|integrationTest)[/\\]java[/\\].*\.java"/>
    <suppress checks="FileLength" files="src[/\\](test|integrationTest)[/\\]java[/\\].*\.java"/>
</suppressions>